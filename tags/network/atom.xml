		<title>WebSocket Problem with Proxy</title>
		<published>2022-03-21T00:00:00+00:00</published>
		<updated>2022-03-21T00:00:00+00:00</updated>
		<link href="https://bittervan.github.io/issue-websocket/" type="text/html"/>
